# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=meeting_intelligence

# API Configuration
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# ===========================================
# MCP Configuration
# ===========================================

# MCP Mode: "live" for real API calls, "mock" for simulated responses
# Start with "mock" to test, then switch to "live" when ready
MCP_MODE=mock

# ===========================================
# OpenAI Configuration (for LLM classification)
# ===========================================
# Get from: https://platform.openai.com/api-keys
# Used to classify action items and determine orchestration actions
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# Notion MCP Configuration
# ===========================================
# 1. Create integration: https://www.notion.so/my-integrations
# 2. Copy the "Internal Integration Token" (starts with secret_)
NOTION_API_KEY=secret_xxxxx

# 3. Create a database for tickets in Notion
# 4. Get database ID from the URL: notion.so/{workspace}/{database_id}?v=...
NOTION_DATABASE_ID=xxxxx

# Optional: Separate database for epics/initiatives
NOTION_EPICS_DATABASE_ID=

# ===========================================
# Google Calendar (env-only OAuth — personal Gmail)
# ===========================================
# Put these in backend/.env on the machine that runs uvicorn (not in the React UI).
# The UI at trycloudflare / Vercel never holds the client secret.
#
# 1. GCP: enable Google Calendar API; create OAuth client (Web or Desktop).
# 2. Get a refresh token, e.g. https://developers.google.com/oauthplayground/
#    — use your OAuth client ID/secret, scope https://www.googleapis.com/auth/calendar,
#    access_type offline / prompt consent so a refresh_token is returned.
# 3. Optional: leave service account vars empty if you only use user OAuth.
# 4. Set MCP_MODE=live (see top of file) for real Calendar API calls.
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
# Optional explicit calendar (default primary = your Google account’s main calendar)
GOOGLE_CALENDAR_ID=
#
# Service account (optional; consumer Gmail cannot send invites without user OAuth above)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_WORKSPACE_DELEGATED_USER=

# ===========================================
# Meeting MCP & calendar invites
# ===========================================
# IANA timezone: "tomorrow at 9am" and Google event wall times use this zone (set to your org).
APP_TIMEZONE=America/Los_Angeles
#
# Notify Participants — SMTP (e.g. Gmail app password, SendGrid, Mailgun SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=you@gmail.com
# SMTP_FROM_NAME=Meeting Intelligence
# SMTP_USE_TLS=true
#
# Optional link line in emails (no trailing slash)
# PUBLIC_APP_URL=https://your-frontend.example

# ===========================================
# Required Notion Database Properties
# ===========================================
# Your Notion database should have these properties:
# - Name (title) - The ticket title
# - Status (status) - Options: "Not started", "In progress", "Done"
# - Type (rich_text) - Story, Task, Bug, etc.
