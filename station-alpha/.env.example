# Must match Meeting Intelligence FastAPI (same cluster + database name).
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=meeting_intelligence

# Zoom Server-to-Server OAuth (webhooks + optional meeting details API)
ZOOM_S2S_ACCOUNT_ID=
ZOOM_S2S_CLIENT_ID=
ZOOM_S2S_CLIENT_SECRET=
ZOOM_S2S_SECRET_TOKEN=

# Used for Zoom URL validation if General app still points bot events here
ZOOM_BOT_SECRET_TOKEN=

# Recall.ai
RECALL_API_KEY=
RECALL_REGION=us-west-2
# Optional display name for the notetaker bot
# RECALL_BOT_DISPLAY_NAME=ZTA Notetaker

# OpenAI (action item extraction)
OPENAI_API_KEY=

# Public base URL (no trailing slash) — tunnel or deployed API, for OAuth redirect only
# PUBLIC_URL=https://your-subdomain.trycloudflare.com

PORT=3001
